<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.newdesign.SearchController"
            prefHeight="800.0" prefWidth="600.0"
            style="-fx-background-color: #F5F5F5;">

    <VBox spacing="15" AnchorPane.topAnchor="0" AnchorPane.leftAnchor="0"
          AnchorPane.rightAnchor="0" AnchorPane.bottomAnchor="0">

        <!-- HEADER -->
        <HBox prefHeight="60"
              style="-fx-background-color: linear-gradient(to right, #0C4D3B, #0EBB8A);
               -fx-background-radius:15;
              -fx-border-radius:15;
               -fx-effect: dropshadow(gaussian, #899793, 15, 0.5, 0, 0);"
              alignment="CENTER_LEFT">

            <padding>
                <Insets top="20" left="20" right="20" bottom="20"/>
            </padding>

            <Label text="SkillDev"
                   style="-fx-text-fill: white; -fx-font-size: 22px; -fx-font-weight: bold;"/>
        </HBox>

        <HBox alignment ="CENTER">

            <Label text="Find Your Skill Match"
                   style = "-fx-background-color: transparent;-fx-text-fill: linear-gradient(to right, #0C4D3B, #0EBB8A); -fx-font-size: 36px; -fx-font-weight: bold;"/>

        </HBox>




        <!-- SEARCH BAR -->
        <HBox alignment="CENTER" spacing="10">
            <TextField fx:id="searchField"
                       promptText="Search users..."
                       prefHeight="40"
                       prefWidth="500"
                       style="-fx-background-color: #EFEFEF;
                              -fx-border-color: #147A5E;
                              -fx-border-radius: 25;
                              -fx-border-width: 2;
                              -fx-background-radius: 25;
                              -fx-padding: 0 15;
                              -fx-font-size: 14px;"/>
        </HBox>


        <!-- RESULTS -->
        <ScrollPane fitToWidth="true"
                    style="-fx-background-color: transparent;"
                    VBox.vgrow="ALWAYS">

            <VBox fx:id="resultsContainer"
                  spacing="10"
                  style="-fx-padding: 10;">
            </VBox>

        </ScrollPane>


        <!-- FOOTER -->
        <HBox alignment="CENTER"
              spacing="50"
              prefHeight="20"
              style="-fx-background-color: linear-gradient(to right, #0C4D3B, #0EBB8A);">

            <Button fx:id="homeButton" text="Home" style="-fx-background-color: transparent; -fx-text-fill: white;" onAction="#handleHomeButton" />
            <Button text="Search" style="-fx-background-color: transparent; -fx-text-fill: white;"/>
            <Label text="AI Chat" style="-fx-text-fill: white;"/>
            <Button fx:id= "profileButton" text="Profile" style="-fx-background-color: transparent; -fx-text-fill: white;" onAction="#handleProfileButton"/>

        </HBox>

    </VBox>

</AnchorPane>