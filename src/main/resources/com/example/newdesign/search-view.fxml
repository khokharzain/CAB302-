<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.example.newdesign.SearchController"
           prefHeight="800.0" prefWidth="600.0"
           style="-fx-background-color: #F5F5F5;">

    <!-- MAIN CONTENT -->
    <VBox spacing="15">

        <!-- HEADER -->
        <HBox fx:id="headerBar"
              prefHeight="60"
              alignment="CENTER_LEFT">

            <padding>
                <Insets top="20" left="20" right="20" bottom="20"/>
            </padding>

            <Label text="SkillDev"
                   style="-fx-text-fill: white; -fx-font-size: 22px; -fx-font-weight: bold;"/>
        </HBox>

        <!-- TITLE -->
        <HBox alignment="CENTER">
            <Label fx:id="searchLabel"
                   text="Find Your Skill Match"
                   style="-fx-background-color: transparent;
                          -fx-text-fill: linear-gradient(to right, #0C4D3B, #0EBB8A);
                          -fx-font-size: 36px;
                          -fx-font-weight: bold;"/>
        </HBox>

        <!-- SEARCH BAR -->
        <HBox alignment="CENTER" spacing="10">
            <TextField fx:id="searchField"
                       promptText="Search users..."
                       prefHeight="40"
                       prefWidth="500"/>
        </HBox>

        <!-- SUGGESTIONS -->
        <VBox fx:id="suggestionsContainer"
              alignment="CENTER"
              spacing="10"/>

        <!-- RESULTS -->
        <ScrollPane fitToWidth="true"
                    VBox.vgrow="ALWAYS"
                    style="-fx-background-color: transparent;">

            <VBox fx:id="resultsContainer"
                  spacing="10"
                  style="-fx-padding: 10;"/>
        </ScrollPane>

        <!-- FOOTER -->
        <HBox fx:id="bottomNav"
              alignment="CENTER"
              spacing="50"
              prefHeight="20">

            <Button fx:id="homeButton"
                    onAction="#handleHomeButton"
                    style="-fx-background-color: transparent;">
                <graphic>
                    <ImageView fitHeight="20" fitWidth="20">
                        <image>
                            <Image url="@Icons/HomeBlack.png"/>
                        </image>
                    </ImageView>
                </graphic>
            </Button>

            <Button fx:id="searchButton"
                    style="-fx-background-color: transparent;">
                <graphic>
                    <ImageView fitHeight="20" fitWidth="20">
                        <image>
                            <Image url="@Icons/SearchBlack.png"/>
                        </image>
                    </ImageView>
                </graphic>
            </Button>
            <Button fx:id="postPageButton"
                    onAction="#handlePostPage"

                    style="-fx-background-color: transparent;">
                <graphic>
                    <ImageView fitHeight="20" fitWidth="20">
                        <image>
                            <Image url="@Icons/post.png"/>
                        </image>
                    </ImageView>
                </graphic>
            </Button>

            <Button fx:id="requestPageButton"
                onAction="#handleRequestPage"
                style="-fx-background-color: transparent;">
                <graphic>
                    <ImageView fitHeight="20" fitWidth="20">
                        <image>
                            <Image url="@Icons/AiBlack.png"/>
                        </image>
                    </ImageView>
                </graphic>
            </Button>

            <Button fx:id="profileButton"
                    onAction="#handleProfileButton"
                    style="-fx-background-color: transparent;">
                <graphic>
                    <ImageView fitHeight="20" fitWidth="20">
                        <image>
                            <Image url="@Icons/profileBlack.png"/>
                        </image>
                    </ImageView>
                </graphic>
            </Button>

        </HBox>

    </VBox>

    <!-- POPUP LAYER -->
    <StackPane fx:id="popupLayer"
               visible="false"
               style="-fx-background-color: rgba(0,0,0,0.4);"/>

</StackPane>