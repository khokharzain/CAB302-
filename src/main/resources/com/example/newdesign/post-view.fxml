<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>

<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.example.newdesign.postController"
           fx:id="rootPane">

    <!-- MAIN UI -->
    <AnchorPane prefHeight="400.0" prefWidth="600.0"
                style="-fx-background-color: #F7F5FA;">

        <VBox AnchorPane.topAnchor="0"
              AnchorPane.leftAnchor="0"
              AnchorPane.rightAnchor="0"
              AnchorPane.bottomAnchor="0">

            <!-- HEADER -->
            <HBox fx:id="headerBar"
                  prefHeight="80"
                  alignment="CENTER_LEFT"
                  style="-fx-background-color: linear-gradient(to right, #0C4D3B, #0EBB8A);">

                <padding>
                    <Insets top="10" left="20" right="20" bottom="10"/>
                </padding>

                <Label text="SkillDev"
                       style="-fx-text-fill: white;
                              -fx-font-size: 22px;
                              -fx-font-weight: bold;"/>
            </HBox>

            <!-- CONTENT -->
            <VBox alignment="TOP_CENTER"
                  spacing="20"
                  VBox.vgrow="ALWAYS"
                  fillWidth="true"
                  style="-fx-padding: 20;">

                <!-- POST CARD -->
                <VBox spacing="15"
                      alignment="CENTER"
                      maxWidth="Infinity"
                      prefHeight="800"
                      style="-fx-background-color: white;
                             -fx-background-radius: 15;
                             -fx-padding: 20;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 15, 0, 0, 5);">

                    <!-- USER INFO -->
                    <HBox spacing="10" alignment="CENTER_LEFT">

                        <StackPane prefWidth="45" prefHeight="45">
                            <ImageView fx:id="profileImage"
                                       fitWidth="45"
                                       fitHeight="45"
                                       preserveRatio="false"/>
                        </StackPane>

                        <VBox>
                            <Label fx:id="userName"
                                   style="-fx-font-weight: bold; -fx-font-size: 15;"/>
                            <Label text="Looking for teammates or offering skills"
                                   style="-fx-text-fill: #888; -fx-font-size: 11;"/>
                        </VBox>
                    </HBox>

                    <!-- TEXT AREA -->
                    <TextArea fx:id="postTextArea"
                              promptText="Hi, I am studying CAB302 at QUT and looking for a teammate with strong Java skills..."
                              wrapText="true"
                              prefHeight="400"/>

                    <!-- FOOTER -->
                    <HBox alignment="CENTER_RIGHT">
                        <Button fx:id="publishButton"
                                text="Publish"
                                onAction="#handlePublish"/>
                    </HBox>

                </VBox>
            </VBox>

            <!-- BOTTOM NAV -->
            <HBox fx:id="bottomNav"
                  alignment="CENTER"
                  spacing="50"
                  prefHeight="40"
                  style="-fx-background-color: linear-gradient(to right, #0C4D3B, #0EBB8A)">

                <Button fx:id="homeButton"
                        onAction="#handleHomeButton"
                        style="-fx-background-color: transparent;">
                    <graphic>
                        <ImageView fitHeight="22" fitWidth="22">
                            <Image url="@Icons/HomeBlack.png"/>
                        </ImageView>
                    </graphic>
                </Button>

                <Button fx:id="searchButton"
                        onAction="#handleSearchButton"
                        style="-fx-background-color: transparent;">
                    <graphic>
                        <ImageView fitHeight="22" fitWidth="22">
                            <Image url="@Icons/SearchBlack.png"/>
                        </ImageView>
                    </graphic>
                </Button>

                <Button fx:id="postButton"
                        style="-fx-background-color: transparent;">
                    <graphic>
                        <ImageView fitHeight="22" fitWidth="22">
                            <Image url="@Icons/post.png"/>
                        </ImageView>
                    </graphic>
                </Button>

                <Button fx:id="profileButton"
                        onAction="#handleProfileButton"
                        style="-fx-background-color: transparent;">
                    <graphic>
                        <ImageView fitHeight="22" fitWidth="22">
                            <Image url="@Icons/profileBlack.png"/>
                        </ImageView>
                    </graphic>
                </Button>

            </HBox>

        </VBox>

    </AnchorPane>

</StackPane>