<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>

<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.example.newdesign.postController"
           fx:id="rootPane">

    <AnchorPane prefHeight="600.0" prefWidth="800.0"
                style="-fx-background-color: #F7F5FA;">

        <VBox AnchorPane.topAnchor="0"
              AnchorPane.leftAnchor="0"
              AnchorPane.rightAnchor="0"
              AnchorPane.bottomAnchor="0">

            <!-- HEADER -->
            <HBox fx:id="headerBar"
                  prefHeight="80"
                  alignment="CENTER_LEFT"
                  style="-fx-background-color: linear-gradient(to right, #0C4D3B, #0EBB8A);">

                <padding>
                    <Insets top="10" left="20" right="20" bottom="10"/>
                </padding>

                <Label text="SkillDev"
                       style="-fx-text-fill: white;
                              -fx-font-size: 22px;
                              -fx-font-weight: bold;"/>
            </HBox>

            <!-- MAIN CONTENT -->
            <VBox alignment="TOP_CENTER"
                  spacing="20"
                  VBox.vgrow="ALWAYS"
                  fillWidth="true"
                  style="-fx-padding: 20;">

                <!-- POST CARD -->
                <VBox spacing="15"
                      alignment="TOP_LEFT"
                      fillWidth="true"

                      style="-fx-background-color: white;
                             -fx-background-radius: 15;
                             -fx-padding: 20;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 15, 0, 0, 5);">

                    <!-- USER INFO -->
                    <HBox spacing="10" alignment="CENTER_LEFT">

                        <StackPane prefWidth="45" prefHeight="45">
                            <ImageView fx:id="profileImage"
                                       fitWidth="45"
                                       fitHeight="45"
                                       preserveRatio="false"/>
                        </StackPane>

                        <VBox>
                            <Label fx:id="userName"
                                   style="-fx-font-weight: bold; -fx-font-size: 15;"/>
                            <Label text="Looking for teammates or offering skills"
                                   style="-fx-text-fill: #888; -fx-font-size: 11;"/>
                        </VBox>
                    </HBox>

                    <!-- POST INPUT -->
                    <TextArea fx:id="postTextArea"
                              promptText="Hi, I am studying CAB302 at QUT and looking for teammates..."
                              wrapText="true"
                              prefHeight="500"
                              style="-fx-background-radius: 10;
                                     -fx-border-radius: 10;"/>

                    <!-- PARTICIPANT + PUBLISH ROW -->
                    <HBox spacing="10" alignment="CENTER_RIGHT">

                        <!-- NEW: Number of participants -->
                        <TextField fx:id="maxParticipantsField"
                                   promptText="People (e.g. 3)"
                                   prefWidth="140"
                                   style="-fx-background-radius: 10;
                                          -fx-border-radius: 10;
                                          -fx-padding: 5;" />

                        <Button fx:id="publishButton"
                                text="Publish"
                                onAction="#handlePublish"
                                style="-fx-background-radius: 10;
                                       -fx-font-weight: bold;
                                       -fx-padding: 8 20;" />
                    </HBox>

                </VBox>
            </VBox>

            <!-- FOOTER -->
            <HBox fx:id="bottomNav"
                  alignment="CENTER"
                  spacing="50"
                  prefHeight="20">

                <Button fx:id="homeButton"
                        onAction="#handleHomeButton"
                        style="-fx-background-color: transparent;">
                    <graphic>
                        <ImageView fitHeight="20" fitWidth="20">
                            <image>
                                <Image url="@Icons/HomeBlack.png"/>
                            </image>
                        </ImageView>
                    </graphic>
                </Button>

                <Button fx:id="searchPageButton"
                        onAction="#handleSearchButton"
                        style="-fx-background-color: transparent;">
                    <graphic>
                        <ImageView fitHeight="20" fitWidth="20">
                            <image>
                                <Image url="@Icons/SearchBlack.png"/>
                            </image>
                        </ImageView>
                    </graphic>
                </Button>
                <Button fx:id="postPageButton"
                        onAction="#handlePostPage"

                        style="-fx-background-color: transparent;">
                    <graphic>
                        <ImageView fitHeight="20" fitWidth="20">
                            <image>
                                <Image url="@Icons/post.png"/>
                            </image>
                        </ImageView>
                    </graphic>
                </Button>

                <Button fx:id="requestPageButton"
                        onAction="#handleRequestPage"
                        style="-fx-background-color: transparent;">
                    <graphic>
                        <ImageView fitHeight="20" fitWidth="20">
                            <image>
                                <Image url="@Icons/AiBlack.png"/>
                            </image>
                        </ImageView>
                    </graphic>
                </Button>

                <Button fx:id="profileButton"
                        onAction="#handleProfileButton"
                        style="-fx-background-color: transparent;">
                    <graphic>
                        <ImageView fitHeight="20" fitWidth="20">
                            <image>
                                <Image url="@Icons/profileBlack.png"/>
                            </image>
                        </ImageView>
                    </graphic>
                </Button>

            </HBox>

        </VBox>

    </AnchorPane>

</StackPane>