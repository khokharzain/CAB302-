<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>


<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.newdesign.controller.MessagerController"
            prefHeight="400.0" prefWidth="600.0">






    <!-- FOOTER -->
    <HBox alignment="CENTER"
          spacing="50"
          prefHeight="20"
          style="-fx-background-color: linear-gradient(to right, #0C4D3B, #0EBB8A);">

        <Button fx:id="homeButton"
                style="-fx-background-color: transparent;" onAction="#handleHomeButton"
        ><graphic>
            <ImageView fitHeight="20" fitWidth="20">
                <image>
                    <Image url="@Icons/HomeBlack.png"/>
                </image>
            </ImageView>
        </graphic>
        </Button>
        <Button fx:id="searchButton"

                style="-fx-background-color: transparent;">
            <graphic>
                <ImageView fitHeight="20" fitWidth="20">
                    <image>
                        <Image url="@Icons/SearchBlack.png"/>
                    </image>
                </ImageView>
            </graphic>
        </Button>

        <Label>
            <graphic>
                <ImageView fitHeight="20" fitWidth="20">
                    <image>
                        <Image url="@Icons/AiBlack.png"/>
                    </image>
                </ImageView>
            </graphic>
        </Label>

        <Button fx:id="profileButton"
                onAction="#handleProfileButton"
                style="-fx-background-color: transparent;">
            <graphic>
                <ImageView fitHeight="20" fitWidth="20">
                    <image>
                        <Image url="@Icons/profileBlack.png"/>
                    </image>
                </ImageView>
            </graphic>
        </Button>

    </HBox>


</AnchorPane>
