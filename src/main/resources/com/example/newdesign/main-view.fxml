<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>

<AnchorPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.newdesign.mainController"
            prefHeight="400.0" prefWidth="600.0"
            style="-fx-background-color: linear-gradient(to bottom right, #E3DCE4, #E3DCE4);">

    <VBox AnchorPane.topAnchor="0"
          AnchorPane.leftAnchor="0"
          AnchorPane.rightAnchor="0"
          AnchorPane.bottomAnchor="0">

        <!-- MAIN CONTENT -->
        <HBox spacing="20" alignment="TOP_LEFT" VBox.vgrow="ALWAYS">

            <padding>
                <Insets top="20" bottom="20" left="20" right="20"/>
            </padding>

            <!-- LEFT SIDE -->
            <VBox fx:id="profileButton"
                  onMouseClicked="#handleClick"
                  prefWidth="200.0"
                  maxHeight="250"
                  alignment="TOP_LEFT"
                  style="-fx-background-color: #F8EEF9;
                         -fx-background-radius: 20;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 25, 0.2, 0, 8);
                         -fx-padding: 20;">

                <GridPane hgap="10" vgap="10">

                    <Label text="Name:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <Label fx:id="firstNameLabel" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                    <Label text="Surname:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                    <Label fx:id="lastNameLabel" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                    <Label text="Email:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                    <Label fx:id="emailLabel" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                    <Label text="Phone:" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                    <Label fx:id="phoneLabel" GridPane.columnIndex="1" GridPane.rowIndex="3"/>

                </GridPane>

            </VBox>

            <!-- RIGHT SIDE -->
            <VBox fx:id="mainContent"
                  HBox.hgrow="ALWAYS"
                  style="-fx-background-color: #F8EEF9;
                         -fx-background-radius: 20;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 25, 0.2, 0, 8);
                         -fx-padding: 20;">
            </VBox>

        </HBox>

        <!-- BOTTOM NAV BAR -->
        <HBox alignment="CENTER"
              spacing="50"
              prefHeight="60"
              style="-fx-background-color: #601C61;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 10, 0.2, 0, -2);">

            <Label text="Home" style="-fx-text-fill: white; -fx-font-size: 14px;"/>
            <Label text="Search" style="-fx-text-fill: white; -fx-font-size: 14px;"/>
            <Label text="Profile" style="-fx-text-fill: white; -fx-font-size: 14px;"/>

        </HBox>

    </VBox>

</AnchorPane>