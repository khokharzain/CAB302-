<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>

<AnchorPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.newdesign.mainController"
            prefHeight="400.0" prefWidth="600.0"
            style="-fx-background-color: linear-gradient(to bottom right, #E3DCE4, #E3DCE4);">

    <VBox AnchorPane.topAnchor="0"
          AnchorPane.leftAnchor="0"
          AnchorPane.rightAnchor="0"
          AnchorPane.bottomAnchor="0">

        <HBox prefHeight="100"
              style="-fx-background-color: linear-gradient(to right, #E752E9, #7D187E);"
              alignment="CENTER_LEFT">

            <padding>
                <Insets top="20" left="20" right="20" bottom="20"/>
            </padding>

            <Label text="SkillDev"
                   style="-fx-text-fill: white; -fx-font-size: 22px; -fx-font-weight: bold;"/>
        </HBox>

        <!-- MAIN CONTENT -->
        <HBox spacing="20" alignment="TOP_LEFT" VBox.vgrow="ALWAYS">

            <padding>
                <Insets top="20" bottom="20" left="20" right="20"/>
            </padding>

            <!-- LEFT SIDE -->
            <VBox fx:id="profilelayout"
                  onMouseClicked="#handleProfClick"
                  prefWidth="200.0"
                  maxHeight="250"
                  alignment="TOP_LEFT"
                  style="-fx-background-color: #F8EEF9;
                         -fx-background-radius: 20;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 25, 0.2, 0, 8);
                         -fx-padding: 20;">

                <GridPane hgap="10" vgap="10">

                    <ImageView fx:id="profilePicture"
                               fitHeight="60"
                               fitWidth="60"
                               GridPane.columnIndex="0"
                               GridPane.columnSpan="2"
                               GridPane.rowIndex="0"/>

                    <Label text="Name:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                    <Label fx:id="firstNameLabel" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                    <Label text="Surname:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                    <Label fx:id="lastNameLabel" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                    <Label text="Email:" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                    <Label fx:id="emailLabel" GridPane.columnIndex="1" GridPane.rowIndex="3"/>

                    <Label text="Phone:" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
                    <Label fx:id="phoneLabel" GridPane.columnIndex="1" GridPane.rowIndex="4"/>

                </GridPane>

            </VBox>

            <!-- RIGHT SIDE -->
            <VBox fx:id="mainContent"
                  HBox.hgrow="ALWAYS"
                  style="-fx-background-color: #F8EEF9;
                         -fx-background-radius: 20;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 25, 0.2, 0, 8);
                         -fx-padding: 20;">
            </VBox>

        </HBox>

        <!-- BOTTOM NAV BAR -->
        <HBox alignment="CENTER"
              spacing="50"
              prefHeight="40"
              style="-fx-background-color: linear-gradient(to left, #E752E9, #7D187E);">

            <Label text="Home" style="-fx-text-fill: white; -fx-font-size: 14px;"/>
            <Button  fx:id="searchButton" text="Search" style=" -fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 14px;" onAction="#handleSearchButton"/>
            <Label text="AI Chat" style ="-fx-text-fill: white; -fx-font-size: 14px;"/>
            <Button fx:id="profileButton" text="Profile" style=" -fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 14px;" onAction="#handleProfileButton"/>

        </HBox>

    </VBox>

</AnchorPane>