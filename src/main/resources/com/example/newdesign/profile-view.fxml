<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.newdesign.ProfileController"
            prefHeight="800" prefWidth="1200">

    <!-- Profile Image -->
    <ImageView fx:id="profileImage"
               fitHeight="150"
               fitWidth="150"
               layoutX="525"
               layoutY="200"
               preserveRatio="true"/>

    <!-- Instruction -->
    <Label text="Click image to change profile picture"
           layoutX="460"
           layoutY="370"/>

    <!-- Back Button -->
    <Button text="Back to Home"
            onAction="#handleBack"
            layoutX="20"
            layoutY="20"/>

</AnchorPane>